<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="URDF">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import URDF urdf file -->
    <xacro:include filename="$(find arm-planner)/urdf/your_robot.urdf" />

    <!-- Import control_xacro -->
    <xacro:include filename="URDF.ros2_control.xacro" />


    <xacro:URDF_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
